.q-tag{display:flex;align-items:center;justify-content:center;border-right:2px solid #eb1000;}
.q-tag span{font-size:1.1vw;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#eb1000;writing-mode:vertical-rl;transform:rotate(180deg);}
.mc{background:#fff;border:1px solid #000;border-radius:0;padding:.4% .6%;display:flex;flex-direction:column;min-height:0;overflow:hidden;}
.mn{font-size:1.1vw;font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#000;margin-bottom:.2em;flex-shrink:0;line-height:1;border-bottom:1.5px solid #eb1000;padding-bottom:.2em;}
