<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FY26 Key Business Dates</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "Segoe UI", Arial, sans-serif; background: #f7f7f7; padding: 0; margin: 0; }

  .fy26c-nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 24px 10px; background: #fff; border-bottom: 1px solid #eee; }
  .fy26c-nav-title { font-size: 15px; font-weight: 700; color: #1a1a1a; }
  .fy26c-nav-sub { font-size: 11px; color: #888; margin-top: 1px; }
  .fy26c-nav-btns { display: flex; gap: 8px; }
  .fy26c-btn { background: #eb1000; color: #fff; border: none; border-radius: 50%; width: 30px; height: 30px; font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-weight: 700; line-height: 1; }
  .fy26c-btn:hover { background: #c50d00; }

  .fy26c-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }

  .fy26c-month { background: #fff; display: flex; flex-direction: column; border-right: 1px solid #eee; }
  .fy26c-month:last-child { border-right: none; }
  .fy26c-banner { height: 8px; background: #eb1000; }
  .fy26c-month-name { font-size: 28px; font-weight: 800; color: #1a1a1a; text-align: center; padding: 16px 0 10px; letter-spacing: -0.5px; }

  .fy26c-cal-wrap { padding: 0 10px; }
  .fy26c-cal { width: 100%; border-collapse: collapse; table-layout: fixed; }
  .fy26c-cal thead tr th { font-size: 11px; font-weight: 700; color: #fff; background: #eb1000; text-align: center; padding: 5px 0; width: 20%; }
  .fy26c-cal thead tr th:first-child { border-radius: 20px 0 0 20px; }
  .fy26c-cal thead tr th:last-child { border-radius: 0 20px 20px 0; }
  .fy26c-cal tbody td { text-align: center; padding: 3px 2px; vertical-align: middle; }

  .fy26c-day { width: 32px; height: 32px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 13px; color: #333; margin: auto; font-weight: 400; }
  .fy26c-day.faded { color: #ccc; }
  .fy26c-day.ev-holiday   { background: #C6C6C6; color: #fff; font-weight: 700; }
  .fy26c-day.ev-earnings  { background: #27BB36; color: #fff; font-weight: 700; }
  .fy26c-day.ev-bod       { background: #eb1000; color: #fff; font-weight: 700; }
  .fy26c-day.ev-qfr       { background: #7B5EA7; color: #fff; font-weight: 700; }
  .fy26c-day.ev-qbr       { background: #33C5E8; color: #fff; font-weight: 700; }
  .fy26c-day.ev-corp      { background: #F69500; color: #fff; font-weight: 700; }
  .fy26c-day.ev-shutdown  { background: #C6C6C6; color: #fff; font-weight: 700; }
  .fy26c-day.ev-allhands  { background: #E8609A; color: #fff; font-weight: 700; }
  .fy26c-day.ev-bizreview { background: #F0D000; color: #fff; font-weight: 700; }
  .fy26c-day.ev-today     { outline: 2px solid #eb1000; outline-offset: 2px; }

  .fy26c-events { padding: 12px 14px 16px; min-height: 80px; border-top: 1px solid #f0f0f0; margin-top: 6px; }
  .fy26c-event { font-size: 11px; margin-bottom: 5px; display: flex; align-items: center; gap: 6px; }
  .fy26c-event-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
  .fy26c-event-text { color: #444; }
  .fy26c-event-text strong { color: #333; font-weight: 700; }

  .fy26c-footer { padding: 12px 24px 16px; }
  .fy26c-legend { display: flex; flex-wrap: wrap; gap: 5px 14px; margin-bottom: 8px; }
  .fy26c-li { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #555; }
  .fy26c-ls { width: 11px; height: 11px; border-radius: 50%; flex-shrink: 0; }
  .fy26c-note { font-size: 12px; color: #888; font-style: italic; }

  @media (max-width: 700px) { .fy26c-grid { grid-template-columns: 1fr; } }
</style>
</head>
<body>

<div class="fy26c-nav">
  <div>
    <div class="fy26c-nav-title">FY26 Key Business Dates</div>
    <div class="fy26c-nav-sub" id="fy26c-range"></div>
  </div>
  <div class="fy26c-nav-btns">
    <button class="fy26c-btn" id="fy26c-prev">&#8249;</button>
    <button class="fy26c-btn" id="fy26c-next">&#8250;</button>
  </div>
</div>

<div class="fy26c-grid" id="fy26c-grid"></div>

<div class="fy26c-footer">
  <div class="fy26c-legend" id="fy26c-legend"></div>
  <div class="fy26c-note">* Many Q3 and Q4 dates are still to be scheduled. This calendar will be updated as dates are confirmed.</div>
</div>

<script>
(function(){
  const LEGEND = [
    {cls:"earnings",  label:"Earnings call",           bg:"#27BB36"},
    {cls:"bod",       label:"Adobe BoD",                bg:"#eb1000"},
    {cls:"qfr",       label:"QFR",                      bg:"#7B5EA7"},
    {cls:"qbr",       label:"QBR",                      bg:"#33C5E8"},
    {cls:"corp",      label:"Corp event",               bg:"#F69500"},
    {cls:"allhands",  label:"Emp. Meeting / All Hands", bg:"#E8609A"},
    {cls:"bizreview", label:"C&P Biz Review",           bg:"#F0D000"},
    {cls:"shutdown",  label:"Shutdown / Holiday",       bg:"#C6C6C6"},
  ];

  const BG = {holiday:"#C6C6C6"};
  LEGEND.forEach(l => BG[l.cls] = l.bg);

  document.getElementById('fy26c-legend').innerHTML = LEGEND.map(l =>
    `<div class="fy26c-li"><div class="fy26c-ls" style="background:${l.bg}"></div>${l.label}</div>`
  ).join('');

  const events = {
    "2025-12-04":{cls:"qbr",      label:"QBR"},
    "2025-12-08":{cls:"qfr",      label:"QFR"},
    "2025-12-10":{cls:"earnings", label:"Earnings Call"},
    "2025-12-16":{cls:"corp",     label:"CKO/SKO"},
    "2025-12-17":{cls:"corp",     label:"CKO/SKO"},
    "2025-12-24":{cls:"shutdown", label:"Shutdown"},
    "2025-12-25":{cls:"shutdown", label:"Shutdown"},
    "2025-12-26":{cls:"shutdown", label:"Shutdown"},
    "2025-12-29":{cls:"shutdown", label:"Shutdown"},
    "2025-12-30":{cls:"shutdown", label:"Shutdown"},
    "2025-12-31":{cls:"shutdown", label:"Shutdown"},
    "2026-01-01":{cls:"shutdown", label:"Shutdown"},
    "2026-01-13":{cls:"bizreview",label:"C&P Biz Review"},
    "2026-01-14":{cls:"bod",      label:"Adobe BoD"},
    "2026-01-15":{cls:"bod",      label:"Adobe BoD"},
    "2026-01-19":{cls:"holiday",  label:"Holiday"},
    "2026-01-27":{cls:"allhands", label:"Emp. Meeting"},
    "2026-02-16":{cls:"holiday",  label:"Holiday"},
    "2026-03-03":{cls:"bizreview",label:"C&P Biz Review"},
    "2026-03-04":{cls:"qbr",      label:"QBR"},
    "2026-03-09":{cls:"qfr",      label:"QFR"},
    "2026-03-12":{cls:"earnings", label:"Earnings Call"},
    "2026-03-16":{cls:"corp",     label:"SLF"},
    "2026-03-17":{cls:"allhands", label:"Emp. Meeting"},
    "2026-03-20":{cls:"holiday",  label:"Holiday"},
    "2026-04-02":{cls:"allhands", label:"Emp. Meeting"},
    "2026-04-07":{cls:"bod",      label:"Adobe BoD"},
    "2026-04-08":{cls:"bod",      label:"Adobe BoD"},
    "2026-04-09":{cls:"bizreview",label:"C&P Biz Review"},
    "2026-04-20":{cls:"corp",     label:"Summit"},
    "2026-04-21":{cls:"corp",     label:"Summit"},
    "2026-04-22":{cls:"corp",     label:"Summit"},
    "2026-05-11":{cls:"corp",     label:"SLF"},
    "2026-05-12":{cls:"corp",     label:"SLF"},
    "2026-05-13":{cls:"corp",     label:"SLF"},
    "2026-05-25":{cls:"holiday",  label:"Holiday"},
    "2026-06-02":{cls:"bizreview",label:"C&P Biz Review"},
    "2026-06-04":{cls:"qbr",      label:"QBR"},
    "2026-06-08":{cls:"qfr",      label:"QFR"},
    "2026-06-11":{cls:"earnings", label:"Earnings Call"},
    "2026-06-16":{cls:"allhands", label:"Emp. Meeting"},
    "2026-06-18":{cls:"bod",      label:"Adobe BoD"},
    "2026-06-19":{cls:"bod",      label:"Adobe BoD"},
    "2026-06-29":{cls:"shutdown", label:"Summer Shutdown"},
    "2026-06-30":{cls:"shutdown", label:"Summer Shutdown"},
    "2026-07-01":{cls:"shutdown", label:"Summer Shutdown"},
    "2026-07-02":{cls:"shutdown", label:"Summer Shutdown"},
    "2026-07-03":{cls:"shutdown", label:"Summer Shutdown"},
    "2026-07-04":{cls:"holiday",  label:"Holiday"},
    "2026-08-21":{cls:"holiday",  label:"Global Day Off"},
    "2026-08-25":{cls:"bizreview",label:"C&P Biz Review"},
    "2026-09-02":{cls:"qbr",      label:"QBR"},
    "2026-09-07":{cls:"holiday",  label:"Holiday"},
    "2026-09-08":{cls:"qfr",      label:"QFR"},
    "2026-09-10":{cls:"earnings", label:"Earnings Call"},
    "2026-09-15":{cls:"allhands", label:"Emp. Meeting"},
    "2026-10-13":{cls:"bizreview",label:"C&P Biz Review"},
    "2026-10-30":{cls:"holiday",  label:"Global Day Off"},
    "2026-11-10":{cls:"corp",     label:"Adobe MAX"},
    "2026-11-11":{cls:"corp",     label:"Adobe MAX"},
    "2026-11-12":{cls:"corp",     label:"Adobe MAX"},
    "2026-11-26":{cls:"holiday",  label:"Holiday"},
    "2026-11-27":{cls:"holiday",  label:"Holiday"},
  };

  const MN = ["January","February","March","April","May","June","July","August","September","October","November","December"];

  function dateKey(y,m,d){ return y+'-'+String(m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0'); }

  const quarters = [
    {label:"Q1", months:[{y:2025,m:11},{y:2026,m:0},{y:2026,m:1}]},
    {label:"Q2", months:[{y:2026,m:2},{y:2026,m:3},{y:2026,m:4}]},
    {label:"Q3", months:[{y:2026,m:5},{y:2026,m:6},{y:2026,m:7}]},
    {label:"Q4", months:[{y:2026,m:8},{y:2026,m:9},{y:2026,m:10}]},
  ];

  const now = new Date();
  let qIdx = 0;
  quarters.forEach((q,i) => {
    const start = new Date(q.months[0].y, q.months[0].m, 1);
    const end   = new Date(q.months[2].y, q.months[2].m+1, 0);
    if(now >= start && now <= end) qIdx = i;
  });

  function buildMonth(y,m){
    const wrap = document.createElement('div');
    wrap.className = 'fy26c-month';
    wrap.innerHTML = `<div class="fy26c-banner"></div><div class="fy26c-month-name">${MN[m]}</div>`;

    const calWrap = document.createElement('div');
    calWrap.className = 'fy26c-cal-wrap';
    const tbl = document.createElement('table');
    tbl.className = 'fy26c-cal';

    const thead = tbl.createTHead();
    const hr = thead.insertRow();
    ['M','T','W','T','F'].forEach(label => {
      const th = document.createElement('th');
      th.textContent = label;
      hr.appendChild(th);
    });

    const dim = new Date(y,m+1,0).getDate();
    const weekdays = [];
    for(let d=1;d<=dim;d++){
      const dow = new Date(y,m,d).getDay();
      if(dow!==0&&dow!==6) weekdays.push(d);
    }

    const firstCol = new Date(y,m,weekdays[0]).getDay()-1;
    const cells = [...Array(firstCol).fill(null), ...weekdays];
    while(cells.length%5!==0) cells.push(null);

    const tbody = tbl.createTBody();
    for(let r=0;r<cells.length/5;r++){
      const row = tbody.insertRow();
      for(let c=0;c<5;c++){
        const d = cells[r*5+c];
        const td = row.insertCell();
        const div = document.createElement('div');
        div.className = 'fy26c-day';
        if(d===null){ div.classList.add('faded'); td.appendChild(div); continue; }
        const ev = events[dateKey(y,m,d)];
        if(ev) div.classList.add('ev-'+ev.cls);
        if(now.getFullYear()===y&&now.getMonth()===m&&now.getDate()===d) div.classList.add('ev-today');
        div.textContent = d;
        td.appendChild(div);
      }
    }
    calWrap.appendChild(tbl);
    wrap.appendChild(calWrap);

    const evGroups = [];
    for(let d=1;d<=dim;d++){
      const ev = events[dateKey(y,m,d)];
      if(!ev) continue;
      const prev = evGroups[evGroups.length-1];
      if(prev&&prev.label===ev.label&&d===prev.end+1){ prev.end=d; }
      else evGroups.push({start:d,end:d,cls:ev.cls,label:ev.label});
    }

    const evDiv = document.createElement('div');
    evDiv.className = 'fy26c-events';
    evGroups.forEach(g => {
      const dateStr = g.start===g.end ? `${g.start}` : `${g.start}–${g.end}`;
      const item = document.createElement('div');
      item.className = 'fy26c-event';
      item.innerHTML = `<div class="fy26c-event-dot" style="background:${BG[g.cls]||'#ccc'}"></div>`
        +`<div class="fy26c-event-text"><strong>${dateStr}</strong> — ${g.label}</div>`;
      evDiv.appendChild(item);
    });
    wrap.appendChild(evDiv);
    return wrap;
  }

  function render(){
    const grid = document.getElementById('fy26c-grid');
    grid.innerHTML = '';
    const q = quarters[qIdx];
    q.months.forEach(({y,m}) => grid.appendChild(buildMonth(y,m)));
    const f=q.months[0], l=q.months[2];
    document.getElementById('fy26c-range').textContent = `${q.label} · ${MN[f.m]} ${f.y} – ${MN[l.m]} ${l.y}`;
  }

  document.getElementById('fy26c-prev').onclick = () => { if(qIdx>0){qIdx--;render();} };
  document.getElementById('fy26c-next').onclick = () => { if(qIdx<quarters.length-1){qIdx++;render();} };
  render();
})();
</script>
</body>
</html>
