.dc{font-size:1.05vw;color:#000;text-align:center;border-radius:0;display:flex;align-items:center;justify-content:center;line-height:1;font-weight:400;padding:0;}
.ev{border-radius:2px;font-size:.82vw;font-weight:700;text-align:center;display:flex;align-items:center;justify-content:center;padding:0 .1em;line-height:1;position:relative;cursor:default;}
