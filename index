<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FY26 Key Business Dates</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "Segoe UI", Arial, sans-serif; background: #f7f7f7; }

  .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 24px 10px; background: #fff; border-bottom: 1px solid #eee; flex-wrap: wrap; gap: 8px; }
  .nav-title { font-size: 15px; font-weight: 700; color: #1a1a1a; }
  .nav-sub { font-size: 11px; color: #888; margin-top: 1px; }
  .nav-btns { display: flex; gap: 8px; }
  .nav-btn { background: #eb1000; color: #fff; border: none; border-radius: 50%; width: 30px; height: 30px; font-size: 18px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-weight: 700; text-decoration: none; line-height: 1; }
  .nav-btn:hover { background: #c50d00; }

  .quarter { display: none; }
  .quarter.active { display: grid; grid-template-columns: repeat(3, 1fr); }

  .month { background: #fff; display: flex; flex-direction: column; border-right: 1px solid #eee; }
  .month:last-child { border-right: none; }
  .banner { height: 8px; background: #eb1000; }
  .month-name { font-size: 28px; font-weight: 800; color: #1a1a1a; text-align: center; padding: 16px 0 10px; }

  .cal-wrap { padding: 0 10px; }
  table.cal { width: 100%; border-collapse: collapse; table-layout: fixed; }
  table.cal thead th { font-size: 11px; font-weight: 700; color: #fff; background: #eb1000; text-align: center; padding: 5px 0; width: 20%; }
  table.cal thead th:first-child { border-radius: 20px 0 0 20px; }
  table.cal thead th:last-child { border-radius: 0 20px 20px 0; }
  table.cal tbody td { text-align: center; padding: 3px 2px; vertical-align: middle; }

  .day { width: 32px; height: 32px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 13px; color: #333; margin: auto; font-weight: 400; }
  .day.faded { color: #ccc; }
  .ev-holiday   { background: #C6C6C6; color: #fff; font-weight: 700; }
  .ev-earnings  { background: #27BB36; color: #fff; font-weight: 700; }
  .ev-bod       { background: #eb1000; color: #fff; font-weight: 700; }
  .ev-qfr       { background: #7B5EA7; color: #fff; font-weight: 700; }
  .ev-qbr       { background: #33C5E8; color: #fff; font-weight: 700; }
  .ev-corp      { background: #F69500; color: #fff; font-weight: 700; }
  .ev-shutdown  { background: #C6C6C6; color: #fff; font-weight: 700; }
  .ev-allhands  { background: #E8609A; color: #fff; font-weight: 700; }
  .ev-bizreview { background: #F0D000; color: #fff; font-weight: 700; }

  .events { padding: 12px 14px 16px; min-height: 80px; border-top: 1px solid #f0f0f0; margin-top: 6px; }
  .event { font-size: 11px; margin-bottom: 5px; display: flex; align-items: center; gap: 6px; }
  .event-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
  .event-text { color: #444; }
  .event-text strong { color: #333; font-weight: 700; }

  .footer { padding: 12px 24px 16px; background: #fff; border-top: 1px solid #eee; }
  .legend { display: flex; flex-wrap: wrap; gap: 5px 14px; margin-bottom: 8px; }
  .li { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #555; }
  .ls { width: 11px; height: 11px; border-radius: 50%; flex-shrink: 0; }
  .note { font-size: 12px; color: #888; font-style: italic; }

  @media (max-width: 700px) { .quarter.active { grid-template-columns: 1fr; } }
</style>
</head>
<body>

<div class="nav">
  <div>
    <div class="nav-title">FY26 Key Business Dates</div>
    <div class="nav-sub" id="qrange"></div>
  </div>
  <div class="nav-btns">
    <button class="nav-btn" id="prev">&#8249;</button>
    <button class="nav-btn" id="next">&#8250;</button>
  </div>
</div>

<div id="cal"></div>

<div class="footer">
  <div class="legend">
    <div class="li"><div class="ls" style="background:#27BB36"></div>Earnings call</div>
    <div class="li"><div class="ls" style="background:#eb1000"></div>Adobe BoD</div>
    <div class="li"><div class="ls" style="background:#7B5EA7"></div>QFR</div>
    <div class="li"><div class="ls" style="background:#33C5E8"></div>QBR</div>
    <div class="li"><div class="ls" style="background:#F69500"></div>Corp event</div>
    <div class="li"><div class="ls" style="background:#E8609A"></div>Emp. Meeting / All Hands</div>
    <div class="li"><div class="ls" style="background:#F0D000"></div>C&amp;P Biz Review</div>
    <div class="li"><div class="ls" style="background:#C6C6C6"></div>Shutdown / Holiday</div>
  </div>
  <div class="note">* Many Q3 and Q4 dates are still to be scheduled. This calendar will be updated as dates are confirmed.</div>
</div>

<script>
const events = {
  "2025-12-04":{cls:"qbr",label:"QBR"},
  "2025-12-08":{cls:"qfr",label:"QFR"},
  "2025-12-10":{cls:"earnings",label:"Earnings Call"},
  "2025-12-16":{cls:"corp",label:"CKO/SKO"},
  "2025-12-17":{cls:"corp",label:"CKO/SKO"},
  "2025-12-24":{cls:"shutdown",label:"Shutdown"},
  "2025-12-25":{cls:"shutdown",label:"Shutdown"},
  "2025-12-26":{cls:"shutdown",label:"Shutdown"},
  "2025-12-29":{cls:"shutdown",label:"Shutdown"},
  "2025-12-30":{cls:"shutdown",label:"Shutdown"},
  "2025-12-31":{cls:"shutdown",label:"Shutdown"},
  "2026-01-01":{cls:"shutdown",label:"Shutdown"},
  "2026-01-13":{cls:"bizreview",label:"C&P Biz Review"},
  "2026-01-14":{cls:"bod",label:"Adobe BoD"},
  "2026-01-15":{cls:"bod",label:"Adobe BoD"},
  "2026-01-19":{cls:"holiday",label:"Holiday"},
  "2026-01-27":{cls:"allhands",label:"Emp. Meeting"},
  "2026-02-16":{cls:"holiday",label:"Holiday"},
  "2026-03-03":{cls:"bizreview",label:"C&P Biz Review"},
  "2026-03-04":{cls:"qbr",label:"QBR"},
  "2026-03-09":{cls:"qfr",label:"QFR"},
  "2026-03-12":{cls:"earnings",label:"Earnings Call"},
  "2026-03-16":{cls:"corp",label:"SLF"},
  "2026-03-17":{cls:"allhands",label:"Emp. Meeting"},
  "2026-03-20":{cls:"holiday",label:"Holiday"},
  "2026-04-02":{cls:"allhands",label:"Emp. Meeting"},
  "2026-04-07":{cls:"bod",label:"Adobe BoD"},
  "2026-04-08":{cls:"bod",label:"Adobe BoD"},
  "2026-04-09":{cls:"bizreview",label:"C&P Biz Review"},
  "2026-04-20":{cls:"corp",label:"Summit"},
  "2026-04-21":{cls:"corp",label:"Summit"},
  "2026-04-22":{cls:"corp",label:"Summit"},
  "2026-05-11":{cls:"corp",label:"SLF"},
  "2026-05-12":{cls:"corp",label:"SLF"},
  "2026-05-13":{cls:"corp",label:"SLF"},
  "2026-05-25":{cls:"holiday",label:"Holiday"},
  "2026-06-02":{cls:"bizreview",label:"C&P Biz Review"},
  "2026-06-04":{cls:"qbr",label:"QBR"},
  "2026-06-08":{cls:"qfr",label:"QFR"},
  "2026-06-11":{cls:"earnings",label:"Earnings Call"},
  "2026-06-16":{cls:"allhands",label:"Emp. Meeting"},
  "2026-06-18":{cls:"bod",label:"Adobe BoD"},
  "2026-06-19":{cls:"bod",label:"Adobe BoD"},
  "2026-06-29":{cls:"shutdown",label:"Summer Shutdown"},
  "2026-06-30":{cls:"shutdown",label:"Summer Shutdown"},
  "2026-07-01":{cls:"shutdown",label:"Summer Shutdown"},
  "2026-07-02":{cls:"shutdown",label:"Summer Shutdown"},
  "2026-07-03":{cls:"shutdown",label:"Summer Shutdown"},
  "2026-07-04":{cls:"holiday",label:"Holiday"},
  "2026-08-21":{cls:"holiday",label:"Global Day Off"},
  "2026-08-25":{cls:"bizreview",label:"C&P Biz Review"},
  "2026-09-02":{cls:"qbr",label:"QBR"},
  "2026-09-07":{cls:"holiday",label:"Holiday"},
  "2026-09-08":{cls:"qfr",label:"QFR"},
  "2026-09-10":{cls:"earnings",label:"Earnings Call"},
  "2026-09-15":{cls:"allhands",label:"Emp. Meeting"},
  "2026-10-13":{cls:"bizreview",label:"C&P Biz Review"},
  "2026-10-30":{cls:"holiday",label:"Global Day Off"},
  "2026-11-10":{cls:"corp",label:"Adobe MAX"},
  "2026-11-11":{cls:"corp",label:"Adobe MAX"},
  "2026-11-12":{cls:"corp",label:"Adobe MAX"},
  "2026-11-26":{cls:"holiday",label:"Holiday"},
  "2026-11-27":{cls:"holiday",label:"Holiday"},
};

const BG = {earnings:"#27BB36",bod:"#eb1000",qfr:"#7B5EA7",qbr:"#33C5E8",corp:"#F69500",allhands:"#E8609A",bizreview:"#F0D000",shutdown:"#C6C6C6",holiday:"#C6C6C6"};
const MN = ["January","February","March","April","May","June","July","August","September","October","November","December"];

const quarters = [
  {label:"Q1",months:[{y:2025,m:11},{y:2026,m:0},{y:2026,m:1}]},
  {label:"Q2",months:[{y:2026,m:2},{y:2026,m:3},{y:2026,m:4}]},
  {label:"Q3",months:[{y:2026,m:5},{y:2026,m:6},{y:2026,m:7}]},
  {label:"Q4",months:[{y:2026,m:8},{y:2026,m:9},{y:2026,m:10}]},
];

function dk(y,m,d){return y+'-'+String(m+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');}

function buildMonth(y,m){
  const dim = new Date(y,m+1,0).getDate();
  const weekdays = [];
  for(let d=1;d<=dim;d++){const dow=new Date(y,m,d).getDay();if(dow!==0&&dow!==6)weekdays.push(d);}
  const firstCol = new Date(y,m,weekdays[0]).getDay()-1;
  const cells = [...Array(firstCol).fill(null),...weekdays];
  while(cells.length%5!==0) cells.push(null);

  let rows = '';
  for(let r=0;r<cells.length/5;r++){
    let tds = '';
    for(let c=0;c<5;c++){
      const d=cells[r*5+c];
      if(d===null){tds+=`<td><div class="day faded"></div></td>`;continue;}
      const ev=events[dk(y,m,d)];
      const cls=ev?` ev-${ev.cls}`:'';
      tds+=`<td><div class="day${cls}">${d}</div></td>`;
    }
    rows+=`<tr>${tds}</tr>`;
  }

  const evGroups=[];
  for(let d=1;d<=dim;d++){
    const ev=events[dk(y,m,d)];
    if(!ev)continue;
    const prev=evGroups[evGroups.length-1];
    if(prev&&prev.label===ev.label&&d===prev.end+1){prev.end=d;}
    else evGroups.push({start:d,end:d,cls:ev.cls,label:ev.label});
  }
  const evHTML=evGroups.map(g=>{
    const ds=g.start===g.end?`${g.start}`:`${g.start}–${g.end}`;
    return `<div class="event"><div class="event-dot" style="background:${BG[g.cls]||'#ccc'}"></div><div class="event-text"><strong>${ds}</strong> — ${g.label}</div></div>`;
  }).join('');

  return `<div class="month">
    <div class="banner"></div>
    <div class="month-name">${MN[m]}</div>
    <div class="cal-wrap">
      <table class="cal">
        <thead><tr><th>M</th><th>T</th><th>W</th><th>T</th><th>F</th></tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>
    <div class="events">${evHTML}</div>
  </div>`;
}

const cal = document.getElementById('cal');
quarters.forEach((q,i)=>{
  const html = q.months.map(({y,m})=>buildMonth(y,m)).join('');
  const div = document.createElement('div');
  div.className = 'quarter'+(i===0?' active':'');
  div.id = 'q'+i;
  div.innerHTML = html;
  cal.appendChild(div);
});

const now = new Date();
let qIdx = 0;
quarters.forEach((q,i)=>{
  const start=new Date(q.months[0].y,q.months[0].m,1);
  const end=new Date(q.months[2].y,q.months[2].m+1,0);
  if(now>=start&&now<=end) qIdx=i;
});

function setQ(i){
  document.querySelectorAll('.quarter').forEach(el=>el.classList.remove('active'));
  document.getElementById('q'+i).classList.add('active');
  const q=quarters[i];
  document.getElementById('qrange').textContent=`${q.label} · ${MN[q.months[0].m]} ${q.months[0].y} – ${MN[q.months[2].m]} ${q.months[2].y}`;
}

setQ(qIdx);
document.getElementById('prev').onclick=()=>{if(qIdx>0){qIdx--;setQ(qIdx);}};
document.getElementById('next').onclick=()=>{if(qIdx<3){qIdx++;setQ(qIdx);}};
</script>
</body>
</html>
